{
  "name": "d-archie-dev",
  "dockerComposeFile": "compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace/DARCHIE",
  "shutdownAction": "stopCompose",
  "remoteUser": "vscode",
  "mounts": [
    "source=${localEnv:HOME}/.codex,target=/home/vscode/.codex,type=bind,consistency=cached"
  ],
  "forwardPorts": [
    3000,
    8000,
    5432,
    6379
  ],
  "portsAttributes": {
    "3000": {
      "label": "Frontend",
      "onAutoForward": "openPreview"
    },
    "8000": {
      "label": "Backend",
      "onAutoForward": "openPreview"
    },
    "5432": {
      "label": "Postgres",
      "onAutoForward": "silent"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "openai.chatgpt",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-azuretools.vscode-docker",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "files.eol": "\n",
        "python.defaultInterpreterPath": "/workspace/DARCHIE/services/api/.venv/bin/python3",
        "python.terminal.activateEnvironment": false,
        "typescript.tsdk": "apps/web/node_modules/typescript/lib",
        "remote.autoForwardPorts": true,
        "remote.restoreForwardedPorts": true,
        "remote.localPortHost": "localhost",
        "remote.autoForwardPortsSource": "process",
        "terminal.integrated.defaultProfile.linux": "bash",
        "python.analysis.extraPaths": [
          "/workspace/DARCHIE/services/api"
        ]
      }
    }
  },
  "containerEnv": {
    "DATABASE_URL": "postgresql://postgres:postgres@postgres:5432/darchie",
    "REDIS_URL": "redis://redis:6379/0",
    "BACKEND_HOST": "0.0.0.0",
    "BACKEND_PORT": "8000",
    "FRONTEND_HOST": "0.0.0.0",
    "FRONTEND_PORT": "3000",
    "NEXT_PUBLIC_API_BASE_URL": "http://localhost:8000"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh"
}
